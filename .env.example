# ==============================================================================
# ⚡ Ratefluencer AI Platform — Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and populate with your own API credentials.
#
# NOTE: To run in high-fidelity mock/presentation fallback mode (no external APIs
# or database servers required), simply copy this file directly to '.env' and
# leave the social and AI credentials blank. The system will auto-mock successfully!
# ==============================================================================

# ------------------------------------------------------------------------------
# 💾 DATABASE & CACHE PARAMETERS
# ------------------------------------------------------------------------------

# DATABASE_URL: Main database connection string.
# - SQLite Local Default: "sqlite:///./ratefluencer.db" (Recommended for offline developer testing)
# - PostgreSQL Docker Default: "postgresql://postgres:postgres@localhost:5432/ratefluencer"
DATABASE_URL=sqlite:///./ratefluencer.db

# REDIS_URL: Redis caching and Celery job queue connection string.
# - Default: "redis://localhost:6379/0"
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# 🛡️ TRACK 1: SOCIAL PLATFORMS & SCRAPING APIs (Optional fallbacks active)
# ------------------------------------------------------------------------------

# INSTAGRAM_ACCESS_TOKEN: Graphic API User Token for live creator lookup profiles.
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_token_here

# REDDIT_CLIENT_ID: Client ID from Reddit App console (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id_here

# REDDIT_CLIENT_SECRET: Client Secret from Reddit App console.
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# REDDIT_USER_AGENT: Custom user agent string for PRAW API request rate compliance.
REDDIT_USER_AGENT=RatefluencerApp/1.0

# YOUTUBE_API_KEY: Browser/Server key from Google Cloud Console enabling YouTube Data API v3.
YOUTUBE_API_KEY=your_google_youtube_api_key_here

# LINKEDIN_ACCESS_TOKEN: OAuth User Access Token for simulating direct publisher endpoints.
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_token_here

# ------------------------------------------------------------------------------
# 🎬 TRACK 2: GENERATIVE AI & VOICE/VIDEO APIs (Optional fallbacks active)
# ------------------------------------------------------------------------------

# ANTHROPIC_API_KEY: Anthropic console token (sk-ant-...) powering Claude 3.5 Sonnet agent scripting.
# - Direct endpoint: claude-3-5-sonnet-20241022
# - If left blank, offline dynamic templates replace active network operations.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPENAI_API_KEY: OpenAI console token (sk-...) used for alternative script layouts or DALL-E image logs.
OPENAI_API_KEY=your_openai_api_key_here

# ELEVENLABS_API_KEY: Voice synthesis token for generating premium simulated script audio voiceovers.
ELEVENLABS_API_KEY=your_elevenlabs_voice_api_key_here

# RUNWAY_API_KEY: Text-to-Video generation token enabling automated video B-roll reel generation.
RUNWAY_API_KEY=your_runway_video_api_key_here

# ------------------------------------------------------------------------------
# 🤝 SEMANTIC SPACE: VECTOR DATABASE SETTINGS (Optional fallbacks active)
# ------------------------------------------------------------------------------

# PINECONE_API_KEY: Pinecone database token for hosting multi-million scale creator vector indexes.
# - If left blank, the platform automatically deploys local in-memory FAISS indices.
PINECONE_API_KEY=your_pinecone_vector_db_key_here

# PINECONE_ENVIRONMENT: Geographical cloud cluster zone (e.g., 'us-west1-gcp' or 'us-east1-gcp').
PINECONE_ENVIRONMENT=us-west1-gcp
