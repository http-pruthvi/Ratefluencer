# ==========================================
# Ratefluencer Environment Configuration
# ==========================================

# Database Configurations
# Default: PostgreSQL when dockerized, falls back to SQLite locally
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ratefluencer
REDIS_URL=redis://localhost:6379/0

# Social & Ingestion APIs (Keep blank to run in mock demo mode)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=Ratefluencer/1.0
YOUTUBE_API_KEY=your_youtube_api_key_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# AI & LLM APIs (Keep blank to run in mock demo mode)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
RUNWAY_API_KEY=your_runway_api_key_here

# Vector Database (Optional, local FAISS used by default)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
