{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "dest": "public/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "public/app.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/main.py"
    },
    {
      "src": "/docs",
      "dest": "api/main.py"
    },
    {
      "src": "/openapi.json",
      "dest": "api/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite:///./ratefluencer.db",
    "FORCE_TFIDF_FALLBACK": "true"
  }
}
